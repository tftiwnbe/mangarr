  "cursorSync": "Off",
  "description": "Mangarr request latency and failure triage from Loki. This dashboard is intentionally outlier-focused because routine successful requests are suppressed by the web and bridge loggers.",
  "editable": true,
  "elements": {
    "panel-1": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "efquzgocpsnpcc"
                    },
                    "group": "loki",
                    "kind": "DataQuery",
                    "spec": {
                      "direction": "backward",
                      "editorMode": "builder",
                      "expr": "{compose_project=\"mangarr\"} | json | __error__=`` | (event=~\"http_request_completed|http_request_failed\" or event=\"http.request.completed\")",
                      "queryType": "range"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Unified request-centric view across web and bridge. This should be your first stop for triage.",
        "id": 1,
        "links": [],
        "title": "All Request Outliers",
        "transparent": true,
        "vizConfig": {
          "group": "logs",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {},
              "overrides": []
            },
            "options": {
              "dedupStrategy": "none",
              "displayedFields": [
                "service",
                "event",
                "method",
                "path",
                "route",
                "route_id",
                "status",
                "duration_ms",
                "request_id",
                "kind",
                "message",
                "error_message",
                "throwable_message"
              ],
              "enableInfiniteScrolling": true,
              "enableLogDetails": false,
              "fontSize": "default",
              "prettifyLogMessage": true,
              "showControls": false,
              "showFieldSelector": true,
              "showLevel": true,
              "showTime": true,
              "sortOrder": "Descending",
              "syntaxHighlighting": true,
              "timestampResolution": "ms",
              "unwrappedColumns": false,
              "wrapLogMessage": true
            }
          },
          "version": "13.1.0"
        }
      }
