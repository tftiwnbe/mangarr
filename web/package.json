		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.4.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"convex": "^1.32.0",
		"convex-svelte": "^0.0.12"
	}
}
