{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"ensure:env": "test -f .env.local || : > .env.local",
		"dev": "pnpm run ensure:env && vite dev --host 0.0.0.0 --port 3737 --strictPort",
		"build": "pnpm run ensure:env && svelte-kit sync && vite build",
		"preview": "pnpm run ensure:env && vite preview --host 0.0.0.0 --port 3737 --strictPort",
		"prepare": "pnpm run ensure:env && ([ -f svelte.config.js ] && [ -x node_modules/.bin/svelte-kit ] && svelte-kit sync || true)",
		"check": "pnpm run ensure:env && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && eslint .",
		"check:watch": "pnpm run ensure:env && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:all": "pnpm run lint && pnpm run check",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"test:e2e": "playwright test",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:unit": "vitest",
		"convex:dev": "convex dev",
		"convex:codegen": "convex codegen"
	},
	"dependencies": {
		"any-ascii": "^0.3.3",
		"bits-ui": "^2.15.5",
		"clsx": "^2.1.1",
		"convex": "^1.32.0",
		"convex-svelte": "^0.0.12",
		"jose": "^6.2.1",
		"phosphor-svelte": "^3.1.0",
		"svelte-i18n": "^4.0.1",
		"tailwind-merge": "^3.4.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.0.18",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"pnpm": {
		"overrides": {
			"svelte-i18n>esbuild": "0.27.3"
		}
	}
}
